# Database Connection URL (e.g., Neon PostgreSQL connection string)
DATABASE_URL=your_postgresql_connection_url_here

# NextAuth Configuration
# For production (Vercel), set NEXTAUTH_URL to your canonical deployment URL (e.g., https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_32_character_string_here

# Optional: Disable Next.js Telemetry collection
NEXT_TELEMETRY_DISABLED=1
